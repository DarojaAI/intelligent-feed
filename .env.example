# ─── Phase 4: Research Pipeline — Cognee Configuration ────────────────────
#
# Copy this file to .env and fill in your values.
# intelligent-feed loads these via CogneeConfig.apply_to_env() before cognify().
#
# See: https://docs.cognee.ai/setup-configuration/overview

# ── LLM — OpenRouter via LiteLLM custom endpoint ──────────────────────────
# LLM_PROVIDER=custom tells LiteLLM to forward to an OpenAI-compatible endpoint.
LLM_PROVIDER=custom
# Model name with openrouter/ prefix.
# Full list: https://openrouter.ai/models
# Recommended cheap models:
#   openrouter/google/gemini-2.0-flash
#   openrouter/openai/gpt-4o-mini
#   openrouter/anthropic/claude-3.5-sonnet
LLM_MODEL=openrouter/google/gemini-2.0-flash
LLM_ENDPOINT=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_TEMPERATURE=0.0

# ── Embeddings ─────────────────────────────────────────────────────────────
# openai: cheaper, good quality (use OPENAI_API_KEY or set EMBEDDING_API_KEY separately)
# ollama: local, no API key (set EMBEDDING_ENDPOINT=http://localhost:11434/api/embed)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_DIMENSIONS=1536

# ── Relational DB + pgvector (same Postgres instance) ─────────────────────
# Install: pip install "cognee[postgres]" psycopg2-binary
# Ensure pgvector extension exists: CREATE EXTENSION IF NOT EXISTS vector;
DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cognee
DB_USERNAME=postgres
DB_PASSWORD=

# Vector store — pgvector uses the Postgres connection above
# Alternatives: lancedb (default, no setup), qdrant, chromadb, redis
VECTOR_DB_PROVIDER=pgvector

# ── Graph store (optional — for entity relationship graph) ─────────────────
# neo4j: full graph traversal
# kuzu: embedded, no server (use VECTOR_DB_PROVIDER=lancedb with kuzu as graph)
# Leave as neptune if using AWS, or set GRAPH_DATABASE_PROVIDER=kuzu for local
GRAPH_DATABASE_PROVIDER=neo4j
GRAPH_DATABASE_URL=bolt://localhost:7687
GRAPH_DATABASE_USERNAME=neo4j
GRAPH_DATABASE_PASSWORD=

# ── Cognee system dirs ──────────────────────────────────────────────────────
DATA_ROOT_DIRECTORY=.cognee_data
SYSTEM_ROOT_DIRECTORY=.cognee_system
